# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cerebras AI (for agent trading decisions)
CEREBRAS_API_KEY=your-cerebras-api-key

# JWT (for session management)
JWT_SECRET=your-jwt-secret-min-32-chars

# Cron (protects evaluation endpoints)
CRON_SECRET=your-cron-secret

# AI Models (optional — defaults shown)
TRADE_MODEL=llama3.1-8b

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# FAL.AI (image generation for avatars/UI)
FAL_API_KEY=your-fal-api-key

# Solana (testnet)
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_PROGRAM_ID=your-program-id-after-deploy
NEXT_PUBLIC_TREASURY_WALLET=your-treasury-wallet-pubkey
SOLANA_ADMIN_PRIVATE_KEY=your-admin-keypair-base58-encoded